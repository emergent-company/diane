<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>CFBundleDevelopmentRegion</key>
    <string>$(DEVELOPMENT_LANGUAGE)</string>
    <key>CFBundleExecutable</key>
    <string>$(EXECUTABLE_NAME)</string>
    <key>CFBundleIdentifier</key>
    <string>$(PRODUCT_BUNDLE_IDENTIFIER)</string>
    <key>CFBundleInfoDictionaryVersion</key>
    <string>6.0</string>
    <key>CFBundleName</key>
    <string>$(PRODUCT_NAME)</string>
    <key>CFBundleDisplayName</key>
    <string>Diane</string>
    <key>CFBundlePackageType</key>
    <string>$(PRODUCT_BUNDLE_PACKAGE_TYPE)</string>
    <key>CFBundleShortVersionString</key>
    <string>0.0.0-DEVELOPMENT</string>
    <key>CFBundleVersion</key>
    <string>1</string>
    <key>LSMinimumSystemVersion</key>
    <string>$(MACOSX_DEPLOYMENT_TARGET)</string>
    <key>LSUIElement</key>
    <true/>
    <key>NSAppTransportSecurity</key>
    <dict>
        <key>NSAllowsArbitraryLoads</key>
        <true/>
    </dict>
    <key>NSHumanReadableCopyright</key>
    <string>Copyright © 2026 Emergent Company. All rights reserved.</string>
    <!-- Sparkle auto-update configuration -->
    <!-- SUPublicEDKey: Generate with: ./bin/generate_keys (from Sparkle distribution) -->
    <!-- Replace the placeholder below with the actual EdDSA public key after key generation -->
    <key>SUPublicEDKey</key>
    <string>REPLACE_WITH_ACTUAL_EdDSA_PUBLIC_KEY</string>
    <!-- SUFeedURL: URL of the appcast XML served with GitHub Releases -->
    <key>SUFeedURL</key>
    <string>https://github.com/emergent-company/diane/releases/latest/download/appcast.xml</string>
    <!-- Enable automatic update checks -->
    <key>SUEnableAutomaticChecks</key>
    <true/>
</dict>
</plist>
