[
  {
    "type_name": "MemoryFact",
    "description": "Personal memory facts — preferences, decisions, patterns, corrections. Stores what the user has said, done, or preferred.",
    "json_schema": {
      "label": "Memory Fact",
      "properties": {
        "fact": {
          "type": "string",
          "description": "The memory fact content"
        },
        "category": {
          "type": "string",
          "description": "Category: user-preference, decision, pattern, entity, action-item"
        },
        "confidence": {
          "type": "number",
          "description": "Confidence 0.0-1.0. 0.9=stated, 0.7=inferred, 0.5=guessed"
        },
        "memory_tier": {
          "type": "integer",
          "description": "Memory tier: 1=per-turn, 2=session-end, 3=dreamed/consolidated"
        },
        "access_count": {
          "type": "integer",
          "description": "Number of times this fact was accessed for reinforcement"
        },
        "source_agent": {
          "type": "string",
          "description": "Creating agent name"
        },
        "source_session": {
          "type": "string",
          "description": "Session/run ID this fact was extracted from"
        }
      },
      "description": "Personal memory facts — preferences, decisions, patterns, corrections"
    },
    "enabled": true
  },
  {
    "type_name": "MCPProxyConfig",
    "description": "MCP proxy server configuration synced from the graph to relay instances",
    "json_schema": {
      "label": "MCP Proxy Config",
      "properties": {
        "scope": {
          "type": "string",
          "description": "Which instance(s): 'all', 'master', 'slave', or specific name"
        },
        "config": {
          "type": "string",
          "description": "Full JSON content of mcp-servers.json"
        },
        "version": {
          "type": "integer",
          "description": "Config version — bump to signal instances to re-pull"
        },
        "instance_id": {
          "type": "string",
          "description": "Target instance name"
        }
      },
      "description": "MCP proxy server configuration synced from graph to relay instances"
    },
    "enabled": true
  },
  {
    "type_name": "MCPSecret",
    "description": "API keys and credentials used by MCP servers registered in the proxy config",
    "json_schema": {
      "label": "MCP Secret",
      "properties": {
        "name": {
          "type": "string",
          "description": "Secret name / identifier"
        },
        "scope": {
          "type": "string",
          "description": "Which instance(s) this secret applies to"
        },
        "value": {
          "type": "string",
          "description": "The secret value (API key, token, etc.) — stored encrypted at rest"
        },
        "description": {
          "type": "string",
          "description": "What this secret is used for"
        }
      },
      "description": "API keys and credentials for MCP servers"
    },
    "enabled": true
  },
  {
    "type_name": "Person",
