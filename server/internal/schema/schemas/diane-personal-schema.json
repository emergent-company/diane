          "type": "string",
          "description": "Relationship or role (friend, colleague, family, etc.)"
        },
        "email": {
          "type": "string",
          "description": "Email address"
        },
        "notes": {
          "type": "string",
          "description": "Personal notes about this person"
        },
        "phone": {
          "type": "string",
          "description": "Phone number"
        }
      },
      "description": "A person known to the user"
    },
    "enabled": true
  },
  {
